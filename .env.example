# ============================================================
# Voice Demo - MongoDB Vector Search
# Copia este archivo como .env y completa los valores
# ============================================================

# MongoDB Atlas connection string
# Obtenerla en: Atlas UI → Connect → Drivers → Python
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Base de datos y coleccion
DB_NAME=Llamadas
COLLECTION_NAME=Llamadas

# Nombre del indice de Vector Search en Atlas
# Debe coincidir con el indice creado en Atlas UI
VECTOR_INDEX_NAME=vector_index

# Campo del documento que contiene el texto para busqueda semantica
# Este campo es el configurado en el indice con type: "autoEmbed"
VECTOR_FIELD=transcripcion_texto
